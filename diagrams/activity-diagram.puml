@startuml activity-diagram
!theme vibrant
skinparam activityBackgroundColor #EEF2FF
skinparam activityBorderColor #6366F1
skinparam activityFontColor #111827
skinparam activityDiamondBackgroundColor #C7D2FE
skinparam activityDiamondFontColor #111827
skinparam activityArrowColor #6366F1
skinparam defaultFontName Segoe UI
skinparam defaultFontSize 11
skinparam defaultFontColor #111827
skinparam shadowing false
skinparam noteBackgroundColor #FFFBEB
skinparam noteBorderColor #F59E0B
skinparam noteFontColor #111827
skinparam swimlaneBorderColor #6366F1
skinparam swimlaneTitleFontColor #111827
skinparam swimlaneBackgroundColor #F8FAFC

title Council Permit Portal — Application Lifecycle

|Applicant|
start
:Browse permit catalogue
or consult AI assistant;
:Select a permit type;
:Fill in application details;
:Upload required documents;
:Pay the application fee;
:Submit the application;

|System|
:Send confirmation email
to the applicant;
:Place application in
the review queue;

|Officer|
:Open the review queue;
:Claim the application;
:Review each document;

if (All documents OK?) then (yes)
  :Recommend Approval;
  |System|
  :Notify admin — ready for sign-off;
  |Admin|
  :Review the application;
  if (Approve?) then (yes)
    |System|
    :Generate PDF certificate;
    :Email certificate to applicant;
    |Applicant|
    :Download certificate from portal;
    stop
  else (no)
    |System|
    :Notify applicant — application rejected;
    stop
  endif
else (no)
  if (Reject outright?) then (yes)
    |Officer|
    :Reject with a written reason;
    |System|
    :Notify applicant of rejection;
    stop
  else (request corrections)
    |Officer|
    :Request corrections and leave a note;
    |System|
    :Email correction details to applicant;
    |Applicant|
    :Read the note;
    :Upload corrected documents;
    :Resubmit;
    |System|
    :Return application to review queue;
    note right
      Application loops back
      to the officer for
      another round of review
    end note
    |Officer|
    :Review the updated documents;
    detach
  endif
endif

@enduml
