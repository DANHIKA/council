@startuml use-case
!theme vibrant
skinparam actorStyle awesome
skinparam usecaseBackgroundColor #EEF2FF
skinparam usecaseBorderColor #4F46E5
skinparam actorBackgroundColor #DBEAFE
skinparam actorBorderColor #1D4ED8
skinparam packageBackgroundColor #F8FAFC
skinparam packageBorderColor #CBD5E1
skinparam ArrowColor #6366F1
skinparam defaultFontName Segoe UI
skinparam defaultFontSize 12
skinparam shadowing false

title Council Permit Portal — Use Case Diagram

' ─────────────────────────── Actors ───────────────────────────
actor "Applicant" as AP #DBEAFE
actor "Officer"   as OF #D1FAE5
actor "Admin"     as AD #FEF3C7
actor "AI System" as AI #F3E8FF
actor "Paychangu\n(Payment GW)" as PG #FFE4E6

' ─────────────────────────── Packages ──────────────────────────

package "Authentication" {
  usecase "Register Account"          as UC_REG
  usecase "Login"                     as UC_LOGIN
  usecase "Update Profile"            as UC_PROFILE
}

package "Permit Discovery" {
  usecase "Browse Permit Catalogue"   as UC_BROWSE
  usecase "Get AI Permit\nRecommendation" as UC_REC
  usecase "View Permit Requirements"  as UC_REQ
  usecase "Chat with AI Assistant"    as UC_CHAT
}

package "Permit Application" {
  usecase "Create Application"        as UC_CREATE
  usecase "Upload Documents"          as UC_UPLOAD
  usecase "Pay Application Fee"       as UC_PAY
  usecase "Submit Application"        as UC_SUBMIT
  usecase "Resubmit After Correction" as UC_RESUB
  usecase "Download Certificate"      as UC_CERT
  usecase "Track Application Status"  as UC_TRACK
}

package "Officer Review" {
  usecase "View Review Queue"         as UC_QUEUE
  usecase "Assign Application"        as UC_ASSIGN
  usecase "Review Documents"          as UC_REVDOC
  usecase "AI Summarise Application"  as UC_SUMM
  usecase "Approve / Recommend"       as UC_APPROVE
  usecase "Reject Application"        as UC_REJECT
  usecase "Require Corrections"       as UC_CORR
  usecase "Add Internal Comment"      as UC_ICOMM
}

package "Admin Management" {
  usecase "Final Sign-off (APPROVE)"  as UC_SIGN
  usecase "Final Sign-off (REJECT)"   as UC_SREJECT
  usecase "Manage Permit Types"       as UC_PTYPE
  usecase "Manage Users"              as UC_USERS
  usecase "View Audit Log"            as UC_AUDIT
  usecase "Manage Withdrawals"        as UC_WITH
  usecase "Renew Certificate"         as UC_RENEW
}

package "Notifications" {
  usecase "Receive Real-time\nNotifications (SSE)" as UC_NOTIF
  usecase "Receive Email Alerts"      as UC_EMAIL
}

' ─────────────────────────── Applicant ─────────────────────────
AP --> UC_REG
AP --> UC_LOGIN
AP --> UC_PROFILE
AP --> UC_BROWSE
AP --> UC_REC
AP --> UC_REQ
AP --> UC_CHAT
AP --> UC_CREATE
AP --> UC_UPLOAD
AP --> UC_PAY
AP --> UC_SUBMIT
AP --> UC_RESUB
AP --> UC_CERT
AP --> UC_TRACK
AP --> UC_NOTIF
AP --> UC_EMAIL

' ─────────────────────────── Officer ───────────────────────────
OF --> UC_LOGIN
OF --> UC_QUEUE
OF --> UC_ASSIGN
OF --> UC_REVDOC
OF --> UC_SUMM
OF --> UC_APPROVE
OF --> UC_REJECT
OF --> UC_CORR
OF --> UC_ICOMM
OF --> UC_CHAT
OF --> UC_NOTIF
OF --> UC_EMAIL

' ─────────────────────────── Admin ─────────────────────────────
AD --> UC_LOGIN
AD --> UC_QUEUE
AD --> UC_SIGN
AD --> UC_SREJECT
AD --> UC_PTYPE
AD --> UC_USERS
AD --> UC_AUDIT
AD --> UC_WITH
AD --> UC_RENEW
AD --> UC_CHAT
AD --> UC_EMAIL

' ─────────────────────────── AI System ─────────────────────────
AI --> UC_REC
AI --> UC_CHAT
AI --> UC_SUMM

' ─────────────────────────── Payment GW ────────────────────────
PG --> UC_PAY

' ─────────────────────────── Include / Extend ──────────────────
UC_SUBMIT  ..> UC_PAY      : <<include>>
UC_SUBMIT  ..> UC_UPLOAD   : <<include>>
UC_RESUB   ..> UC_UPLOAD   : <<include>>
UC_SIGN    ..> UC_EMAIL    : <<include>>
UC_APPROVE ..> UC_EMAIL    : <<include>>
UC_REJECT  ..> UC_EMAIL    : <<include>>
UC_CORR    ..> UC_EMAIL    : <<include>>
UC_SUMM    ..> AI          : <<include>>
UC_CERT    ..> UC_SIGN     : <<extend>>

@enduml
