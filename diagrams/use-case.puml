@startuml use-case
!theme vibrant
left to right direction

skinparam defaultFontName Segoe UI
skinparam defaultFontSize 11
skinparam defaultFontColor #111827
skinparam shadowing false
skinparam actorBackgroundColor #DBEAFE
skinparam actorBorderColor #1D4ED8
skinparam usecaseBackgroundColor #EEF2FF
skinparam usecaseBorderColor #6366F1
skinparam usecaseFontColor #111827
skinparam actorFontColor #111827
skinparam noteBackgroundColor #FFFBEB
skinparam noteBorderColor #F59E0B
skinparam noteFontColor #111827
skinparam rectangleBackgroundColor #F8FAFC
skinparam rectangleBorderColor #6366F1
skinparam rectangleFontColor #111827

title Council Permit Portal — Use Case Diagram

actor "Applicant"       as AP #DBEAFE
actor "Officer"         as OF #E0E7FF

rectangle "Council Permit Portal" {
  usecase "Browse Permit Catalogue"   as UC1
  usecase "Start Application"         as UC2
  usecase "Upload Documents"          as UC3
  usecase "Pay Application Fee"       as UC4
  usecase "Submit Application"        as UC5
  usecase "Track Application Status"  as UC6
  usecase "Download Certificate"      as UC7
  usecase "Chat with AI Assistant"    as UC8
  usecase "View Review Queue"         as UC9
  usecase "Claim & Review Application" as UC10
  usecase "Approve / Reject Documents" as UC11
  usecase "AI Summarise Application"  as UC12
  usecase "Recommend Approval"        as UC13
  usecase "Request Corrections"       as UC14
  usecase "Reject Application"        as UC15
  usecase "Final Sign-off"            as UC16
  usecase "Manage Permit Types"       as UC17
  usecase "Manage Users"              as UC18
  usecase "View Audit Log"            as UC19
  usecase "Manage Withdrawals"        as UC20
  usecase "Renew Certificate"         as UC21

  ' Force a single vertical column
  UC1  -[hidden]down-> UC2
  UC2  -[hidden]down-> UC3
  UC3  -[hidden]down-> UC4
  UC4  -[hidden]down-> UC5
  UC5  -[hidden]down-> UC6
  UC6  -[hidden]down-> UC7
  UC7  -[hidden]down-> UC8
  UC8  -[hidden]down-> UC9
  UC9  -[hidden]down-> UC10
  UC10 -[hidden]down-> UC11
  UC11 -[hidden]down-> UC12
  UC12 -[hidden]down-> UC13
  UC13 -[hidden]down-> UC14
  UC14 -[hidden]down-> UC15
  UC15 -[hidden]down-> UC16
  UC16 -[hidden]down-> UC17
  UC17 -[hidden]down-> UC18
  UC18 -[hidden]down-> UC19
  UC19 -[hidden]down-> UC20
  UC20 -[hidden]down-> UC21
}

actor "Admin"           as AD #EDE9FE
actor "AI System"       as AI #FEF3C7
actor "Payment System"  as PAY #D1FAE5

' Applicant — left side
AP -- UC1
AP -- UC2
AP -- UC3
AP -- UC4
AP -- UC5
AP -- UC6
AP -- UC7
AP -- UC8

' Officer — left side
OF -- UC9
OF -- UC10
OF -- UC11
OF -- UC12
OF -- UC13
OF -- UC14
OF -- UC15

' Admin — right side (reverse direction keeps actor on the right)
UC16 -- AD
UC17 -- AD
UC18 -- AD
UC19 -- AD
UC20 -- AD
UC21 -- AD

' External systems — right side
UC4  -- PAY
UC8  -- AI
UC12 -- AI

@enduml
