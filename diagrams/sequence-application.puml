@startuml sequence-application
!theme vibrant
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 8
skinparam participantBackgroundColor #EEF2FF
skinparam participantBorderColor #6366F1
skinparam actorBackgroundColor #DBEAFE
skinparam actorBorderColor #1D4ED8
skinparam sequenceGroupBackgroundColor #F8FAFC
skinparam sequenceGroupBorderColor #CBD5E1
skinparam noteBackgroundColor #FFFBEB
skinparam noteBorderColor #F59E0B
skinparam defaultFontName Segoe UI
skinparam defaultFontSize 11
skinparam defaultFontColor #111827
skinparam shadowing false
skinparam sequenceParticipantFontColor #111827
skinparam sequenceActorFontColor #111827
skinparam sequenceMessageFontColor #111827
skinparam sequenceGroupFontColor #111827
skinparam noteFontColor #111827

title Council Permit Portal — Application Lifecycle

actor "Applicant" as AP #DBEAFE
actor "Officer"   as OF #E0E7FF
actor "Admin"     as AD #EDE9FE
participant "Portal\n(Website)"            as UI  #E0E7FF
participant "System\n(Server + Database)"  as SYS #EDE9FE
participant "Payment\nSystem"              as PAY #D1FAE5
participant "Email"                        as EMAIL #FEF3C7

' ─── 1. START APPLICATION ─────────────────────────────────────
== 1. Start a New Application ==
AP -> UI  : Picks a permit type and starts an application
UI -> SYS : Creates a draft application
SYS --> UI : Draft saved — applicant can return and continue later

' ─── 2. UPLOAD DOCUMENTS ──────────────────────────────────────
== 2. Upload Supporting Documents ==
AP -> UI  : Uploads required documents (ID, plans, photos, etc.)
UI -> SYS : Stores each document against the application
SYS --> UI : Confirms each upload was received

' ─── 3. PAY THE FEE ───────────────────────────────────────────
== 3. Pay the Application Fee ==
AP -> UI  : Clicks "Pay Fee"
UI -> PAY : Opens the payment page
PAY --> AP : Applicant completes payment on the payment page
PAY -> SYS : Confirms payment was received
SYS --> UI : Application marked as "Paid"

' ─── 4. SUBMIT ────────────────────────────────────────────────
== 4. Submit the Application ==
AP -> UI  : Clicks "Submit"
UI -> SYS : Marks the application as submitted
SYS -> EMAIL : Sends a confirmation email to the applicant
SYS --> UI  : Submission confirmed

' ─── 5. OFFICER REVIEW ────────────────────────────────────────
== 5. Officer Reviews the Application ==
OF -> UI  : Opens the review queue and claims the application
SYS --> UI : Application assigned to the officer

OF -> UI  : Reviews each uploaded document

alt All documents OK — recommending approval
  OF -> UI  : Clicks "Recommend Approval"
  UI -> SYS : Records the recommendation
  SYS -> EMAIL : Notifies admin that the application is ready for sign-off
  SYS --> UI  : Status set to "Pending Approval"

else Issues found — requesting corrections
  OF -> UI  : Clicks "Request Corrections" and leaves a note
  UI -> SYS : Records the correction request
  SYS -> EMAIL : Emails the applicant with the correction details
  SYS --> UI  : Status set to "Awaiting Corrections"
  AP -> UI  : Reads the note, uploads corrected documents, and resubmits
  note right: Loops back to officer review

else Application rejected
  OF -> UI  : Clicks "Reject" and gives a reason
  UI -> SYS : Records the rejection
  SYS -> EMAIL : Notifies the applicant of the rejection
end

' ─── 6. ADMIN SIGN-OFF ────────────────────────────────────────
== 6. Admin Final Sign-off ==
alt Admin signs off via the portal
  AD -> UI  : Opens the application and clicks "Approve" or "Reject"
  UI -> SYS : Records the admin's decision
  SYS --> UI : Status updated

else Admin signs off via the email link
  AD -> EMAIL : Clicks the approval or rejection link in the notification email
  EMAIL -> SYS : Records the decision
  SYS --> UI  : Status updated
end

SYS -> EMAIL : Notifies the applicant of the outcome

' ─── 7. GENERATE CERTIFICATE ──────────────────────────────────
== 7. Certificate Generated (if Approved) ==
SYS -> SYS : Generates a PDF certificate with permit details and QR code
SYS -> EMAIL : Emails the certificate to the applicant

' ─── 8. DOWNLOAD CERTIFICATE ──────────────────────────────────
== 8. Applicant Downloads the Certificate ==
AP -> UI  : Opens the application and clicks "Download Certificate"
UI -> SYS : Requests the certificate file
SYS --> UI : Certificate delivered for download

@enduml
