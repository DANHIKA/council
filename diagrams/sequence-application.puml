@startuml sequence-application
!theme vibrant
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 8
skinparam participantBackgroundColor #EEF2FF
skinparam participantBorderColor #6366F1
skinparam actorBackgroundColor #DBEAFE
skinparam actorBorderColor #1D4ED8
skinparam sequenceGroupBackgroundColor #F8FAFC
skinparam sequenceGroupBorderColor #CBD5E1
skinparam noteBackgroundColor #FFFBEB
skinparam noteBorderColor #F59E0B
skinparam defaultFontName Segoe UI
skinparam defaultFontSize 11
skinparam shadowing false

title Council Permit Portal — Permit Application Sequence

actor Applicant as AP #DBEAFE
participant "UI"     as UI #E0E7FF
participant "API"    as API #EDE9FE
participant "DB"     as DB #D1FAE5
participant "Paychangu" as PAY #FEF3C7
participant "Email"  as MAIL #FFE4E6
actor Officer as OF #D1FAE5
actor Admin   as AD #FEF3C7

' ─── 1. LOGIN ───────────────────────────────────────────────
AP -> UI  : Login
UI -> API : Verify credentials (Supabase JWT)
API --> UI : Session {role: APPLICANT}

' ─── 2. CREATE APPLICATION ──────────────────────────────────
AP -> UI  : Select permit type, fill form + location
UI -> API : POST /api/applications
API -> DB : Create PermitApplication (status: SUBMITTED)
API --> UI : {applicationId}

' ─── 3. UPLOAD DOCUMENTS ────────────────────────────────────
AP -> UI  : Upload required documents
UI -> API : POST /api/applications/{id}/documents
API -> API : Validate file type
API --> UI : Document saved

' ─── 4. PAYMENT ─────────────────────────────────────────────
alt Fee > 0
  AP -> UI  : Click "Pay Now"
  UI -> API : POST /api/payments/initiate
  API -> PAY : Create checkout
  PAY --> UI : Redirect to Paychangu

  AP -> PAY : Complete payment
  PAY -> API : GET /api/payments/callback
  API -> PAY : Verify transaction
  API -> DB  : Payment → PAID
  API --> UI : Redirect → application page

else Fee = 0
  API -> DB : Payment → WAIVED
end

' ─── 5. SUBMIT ──────────────────────────────────────────────
AP -> UI  : Click "Submit Application"
UI -> API : POST /api/applications/{id}/submit
API -> DB : Validate docs + payment, status → UNDER_REVIEW
API -> DB : Notify Officers
API --> UI : Status: Under Review

' ─── 6. OFFICER REVIEW ──────────────────────────────────────
OF -> UI  : Open review queue, select application
UI -> API : GET /api/officer/applications/{id}

alt Requires Corrections
  OF -> UI  : Add notes, click "Require Corrections"
  UI -> API : POST decision {REQUIRES_CORRECTION}
  API -> MAIL : Email Applicant with notes
  AP -> UI  : Re-upload documents, click "Resubmit"
  UI -> API : POST /api/applications/{id}/resubmit
  note right: Status → UNDER_REVIEW, loops back

else Recommend Approval
  OF -> UI  : Click "Approve"
  UI -> API : POST decision {APPROVE}
  API -> DB  : Status → PENDING_APPROVAL
  API -> MAIL : Email all Admins with sign-off links (48h token)

else Reject
  OF -> UI  : Click "Reject" with reason
  UI -> API : POST decision {REJECT}
  API -> MAIL : Email Applicant — rejected
end

' ─── 7. ADMIN SIGN-OFF ──────────────────────────────────────
AD -> MAIL : Click "Approve" link in email
MAIL -> API : GET /api/email-action/{token}
API -> DB  : Validate token (not used, not expired)
API -> DB  : Status → APPROVED, generate Certificate
API -> MAIL : Email Applicant — approved

' ─── 8. DOWNLOAD CERTIFICATE ────────────────────────────────
AP -> UI  : Click "Download Certificate"
UI -> API : GET /api/applications/{id}/certificate/download
API --> UI : PDF stream
UI --> AP : Browser downloads certificate

@enduml
