@startuml sequence-ai-chat
!theme vibrant
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 8
skinparam participantBackgroundColor #EEF2FF
skinparam participantBorderColor #6366F1
skinparam actorBackgroundColor #DBEAFE
skinparam actorBorderColor #1D4ED8
skinparam sequenceGroupBackgroundColor #F8FAFC
skinparam sequenceGroupBorderColor #CBD5E1
skinparam noteBackgroundColor #FFFBEB
skinparam noteBorderColor #F59E0B
skinparam defaultFontName Segoe UI
skinparam defaultFontSize 11
skinparam shadowing false

title Council Permit Portal — AI Chat Sequence

actor User as U #DBEAFE
participant "Chat UI" as UI #E0E7FF
participant "API /ai/chat" as API #EDE9FE
participant "DB"          as DB #D1FAE5
participant "AI Provider\n(Groq / Gemini)" as AI #FEF3C7

' ─── SESSION LOAD ────────────────────────────────────────────
U -> UI  : Open /chat
UI -> DB : Load chat sessions
DB --> UI : ChatSession[] shown in SubSidebar

alt New chat
  U -> UI : Click "New Chat"
else Resume session
  U -> UI : Click existing session
  UI -> DB : Load messages for session
  DB --> UI : ChatMessage[] restored
end

' ─── SEND MESSAGE ────────────────────────────────────────────
U -> UI  : Type message + press Enter
UI -> API : POST /api/ai/chat {message, messages[], sessionId?}

API -> API : classifyIntent(message)

alt permit_recommendation
  API -> DB : Fetch all PermitTypes + scenarios
  DB --> API : permit list

else document_requirements
  API -> API : Detect permit name from conversation
  API -> DB  : Fetch PermitRequirements for that permit
  DB --> API : requirements

else process_inquiry
  API -> API : Detect permit name from conversation
  alt Permit found
    API -> DB : Fetch steps for that permit
  else No permit identified
    API -> DB : Fetch all permit names
    API -> API : serverSuggestions = [permit names, "Other"]
    note right: UI will show chips — AI writes one sentence only
  end

else my_applications
  API -> DB : Fetch user's applications
  DB --> API : application list

else greeting / conversation
  note right: No DB fetch
end

API -> AI  : Chat completion {system prompt + data + messages}
AI --> API : Response text

API -> API : Parse [SUGGEST: a | b] from response
API -> DB  : Save ChatSession + ChatMessages

API --> UI : {response, suggestions[], visualization?, action?}

' ─── RENDER ─────────────────────────────────────────────────
UI --> U : Render markdown response

alt suggestions present
  UI --> U : Show suggestion chips (permit names / "Other")
  U -> UI  : Click chip → send as next message
end

alt visualization present
  UI --> U : Render chart (bar / pie / table)
end

alt action present
  UI --> U : Render action card (e.g. "Start Application")
end

@enduml
