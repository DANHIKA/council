@startuml component-architecture
!theme vibrant
skinparam componentBackgroundColor #EEF2FF
skinparam componentBorderColor #6366F1
skinparam componentFontColor #111827
skinparam packageBackgroundColor #F8FAFC
skinparam packageBorderColor #CBD5E1
skinparam packageFontColor #111827
skinparam databaseBackgroundColor #D1FAE5
skinparam databaseBorderColor #059669
skinparam databaseFontColor #111827
skinparam cloudBackgroundColor #FEF3C7
skinparam cloudBorderColor #F59E0B
skinparam cloudFontColor #111827
skinparam defaultFontName Segoe UI
skinparam defaultFontSize 11
skinparam defaultFontColor #111827
skinparam arrowColor #6366F1
skinparam shadowing false
skinparam noteBackgroundColor #FFFBEB
skinparam noteBorderColor #F59E0B
skinparam noteFontColor #111827

title Council Permit Portal — Component Architecture

package "Next.js Application" {

  package "Pages (App Router)" {
    [Dashboard]            as DASH
    [Applications]         as APPS
    [New Application]      as NEW_APP
    [Application Detail]   as APP_DETAIL
    [Review Queue]         as OFF_QUEUE
    [Review Application]   as OFF_REVIEW
    [Admin Dashboard]      as ADMIN_DASH
    [Permit Types (Admin)] as ADMIN_PERMITS
    [Users (Admin)]        as ADMIN_USERS
    [Audit Log (Admin)]    as ADMIN_AUDIT
    [Permit Map]           as MAP
    [AI Chat]              as CHAT
  }

  package "Components" {
    [Navigation Header\n+ Breadcrumbs] as NAV
    [Application Form]     as FORM
    [Document Uploader]    as UPLOADER
    [Chat Interface]       as CHAT_UI
    [Chart Visualizations] as CHARTS
  }

  package "API Routes" {
    [Applications API]  as API_APPS
    [Documents API]     as API_DOCS
    [Payments API]      as API_PAY
    [AI Chat API]       as API_CHAT
    [Admin API]         as API_ADMIN
    [Officer API]       as API_OFF
    [Certificates API]  as API_CERT
    [Notifications API] as API_NOTIF
  }

  package "Libraries" {
    [RBAC\n(lib/rbac)]       as RBAC
    [Prisma\n(Database Client)] as PRISMA
    [Supabase SDK\n(File Storage)] as STORAGE
    [Email Service]          as EMAIL_LIB
    [PDF Generator]          as PDF
  }
}

package "External Services" {
  database "Supabase Cloud\n(PostgreSQL + File Storage)" as SUPA #D1FAE5
  cloud "AI Providers\n(Groq / Gemini / Ollama)"         as AI_SVC #FEF3C7
  [Paychangu\n(Payments)]                                as PAYCHANGU #D1FAE5
  [Email Provider\n(SMTP / SendGrid)]                    as EMAIL_SVC #FEF3C7
}

' Pages → Components
APPS      --> FORM
NEW_APP   --> FORM
NEW_APP   --> UPLOADER
APP_DETAIL --> UPLOADER
CHAT      --> CHAT_UI
CHAT_UI   --> CHARTS

' Pages → API Routes
APPS       --> API_APPS
APP_DETAIL --> API_APPS
APP_DETAIL --> API_DOCS
NEW_APP    --> API_APPS
OFF_QUEUE  --> API_OFF
OFF_REVIEW --> API_OFF
OFF_REVIEW --> API_DOCS
ADMIN_DASH     --> API_ADMIN
ADMIN_PERMITS  --> API_ADMIN
ADMIN_USERS    --> API_ADMIN
ADMIN_AUDIT    --> API_ADMIN
CHAT       --> API_CHAT

' API Routes → Libraries
API_APPS   --> PRISMA
API_DOCS   --> PRISMA
API_DOCS   --> STORAGE
API_PAY    --> PRISMA
API_CHAT   --> PRISMA
API_ADMIN  --> PRISMA
API_OFF    --> PRISMA
API_CERT   --> PDF
API_CERT   --> STORAGE
API_NOTIF  --> EMAIL_LIB

' Libraries → External Services
PRISMA     --> SUPA
STORAGE    --> SUPA
API_PAY    --> PAYCHANGU
API_CHAT   --> AI_SVC
EMAIL_LIB  --> EMAIL_SVC

' RBAC used across pages and nav
RBAC --> NAV
RBAC --> API_APPS
RBAC --> API_ADMIN
RBAC --> API_OFF

@enduml
